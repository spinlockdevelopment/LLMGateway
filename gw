#!/usr/bin/env python3
"""
gw — LLM Gateway helper
========================
Usage:
    ./gw                         Show status of all components + key paths
    ./gw start <component>       Start a component
    ./gw stop <component>        Stop a component
    ./gw restart <component>     Restart a component
    ./gw logs <component>        Tail logs for a component
    ./gw uninstall               Deregister all autostart, stop containers

Components:
    management     Gateway management service (llmgateway.py / launchd)
    whisper-server whisper.cpp server (bare metal, default port 8083)
    docker         Entire Docker Compose stack
    litellm        LiteLLM proxy container
    postgres       PostgreSQL container
    grafana        Grafana dashboards container (if observability enabled)
    prometheus     Prometheus metrics container (if observability enabled)
    loki           Loki log aggregation container (if observability enabled)
    alloy          Grafana Alloy collector container (if observability enabled)

Console output: clean, no timestamps. Warnings in yellow, errors in red.
Log file: <data_dir>/logs/gw.log — full timestamps, overwritten each run.
"""

from __future__ import annotations

import datetime
import json
import logging
import os
import subprocess
import sys
import time
import urllib.request
from pathlib import Path

# ── Path setup ────────────────────────────────────────────────────────────────
REPO_DIR = Path(__file__).parent.resolve()
sys.path.insert(0, str(REPO_DIR / "scripts"))

# Import shared modules — graceful fallback if something is broken
try:
    from console import (
        info, success, warn, error, bold, dim, green, red, yellow, cyan,
        heading, separator, blank,
    )
    from data_dir import get_data_dir, log_dir
except ImportError:
    # Minimal fallback if scripts/ is broken
    def info(msg=""): print(msg)
    def success(msg): print(f"  + {msg}")
    def warn(msg): print(f"  ? Warning: {msg}")
    def error(msg): print(f"  x Error: {msg}")
    def bold(t): return t
    def dim(t): return t
    def green(t): return t
    def red(t): return t
    def yellow(t): return t
    def cyan(t): return t
    def heading(t): print(f"\n  {t}")
    def separator(w=88): print(f"  {'─' * w}")
    def blank(): print()
    def get_data_dir(): return Path.home() / ".llm-gateway"
    def log_dir(): return get_data_dir() / "logs"


# ── Constants ─────────────────────────────────────────────────────────────────
COMPOSE_FILE = REPO_DIR / "docker" / "docker-compose.yml"
COMPOSE_OBS_FILE = REPO_DIR / "docker" / "docker-compose.observability.yml"
MANAGEMENT_LABEL = "com.local.llm-gateway"
MANAGEMENT_SCRIPT = REPO_DIR / "scripts" / "llmgateway.py"
MANAGEMENT_PLIST = Path.home() / "Library" / "LaunchAgents" / f"{MANAGEMENT_LABEL}.plist"
MANAGEMENT_PORT = 8080
WHISPER_SERVER_DEFAULT_PORT = 8083


# ── Log file setup ───────────────────────────────────────────────────────────

def _setup_log_file() -> None:
    """Set up a log file at <data_dir>/logs/gw.log, overwritten each run."""
    try:
        log_path = log_dir() / "gw.log"
        log_path.parent.mkdir(parents=True, exist_ok=True)
        logging.basicConfig(
            filename=str(log_path),
            filemode="w",
            level=logging.DEBUG,
            format="%(asctime)s [%(levelname)-8s] %(message)s",
            datefmt="%Y-%m-%d %H:%M:%S",
        )
    except Exception:
        pass


def _log(msg: str, level: str = "INFO") -> None:
    """Write to the log file (timestamps + levels). Does NOT print to console."""
    getattr(logging, level.lower(), logging.info)(msg)


# ── Install config (which components are enabled) ────────────────────────────

def _load_install_config() -> dict:
    """Load install choices from llmgateway.yaml install: section."""
    config_path = get_data_dir() / "config" / "llmgateway.yaml"
    if not config_path.exists():
        return {}
    try:
        import yaml
        data = yaml.safe_load(config_path.read_text(encoding="utf-8")) or {}
        return data.get("install", {})
    except ImportError:
        # Fallback: simple parser for flat YAML
        result = {}
        try:
            in_install = False
            for line in config_path.read_text(encoding="utf-8").splitlines():
                stripped = line.strip()
                if not stripped or stripped.startswith("#"):
                    continue
                if stripped == "install:":
                    in_install = True
                    continue
                if in_install and not line.startswith(" "):
                    break
                if in_install and ":" in stripped:
                    key, _, val = stripped.partition(":")
                    val = val.strip()
                    if val.lower() == "true":
                        result[key.strip()] = True
                    elif val.lower() == "false":
                        result[key.strip()] = False
                    else:
                        result[key.strip()] = val
        except Exception:
            pass
        return result
    except Exception:
        return {}


def _observability_enabled() -> bool:
    """Return True if observability stack was selected during setup."""
    return _load_install_config().get("install_observability", False)


def _enabled_components() -> set[str]:
    """Return set of component names that should appear in status."""
    config = _load_install_config()
    components = {"management", "docker", "litellm", "postgres"}
    if config.get("install_observability", False):
        components.update({"grafana", "prometheus", "loki", "alloy"})
    if config.get("install_whisper", False):
        components.add("whisper-server")
    return components


# ── Status check helpers ──────────────────────────────────────────────────────

def _http_ok(url: str, timeout: int = 2) -> bool:
    try:
        resp = urllib.request.urlopen(url, timeout=timeout)
        return 200 <= resp.status < 400
    except Exception:
        return False


def _process_running(pattern: str) -> bool:
    try:
        result = subprocess.run(
            ["pgrep", "-qf", pattern],
            capture_output=True, timeout=5,
        )
        return result.returncode == 0
    except Exception:
        return False


def docker_available() -> bool:
    try:
        result = subprocess.run(["docker", "info"], capture_output=True, timeout=10)
        return result.returncode == 0
    except Exception:
        return False


def docker_container_state(container: str) -> str:
    """Returns: running | starting | stopped | unhealthy | absent"""
    try:
        result = subprocess.run(
            ["docker", "inspect", "--format", "{{.State.Status}}", container],
            capture_output=True, text=True, timeout=10,
        )
        if result.returncode != 0:
            return "absent"
        status = result.stdout.strip()
        if status == "running":
            health_result = subprocess.run(
                ["docker", "inspect", "--format",
                 "{{if .State.Health}}{{.State.Health.Status}}{{end}}", container],
                capture_output=True, text=True, timeout=10,
            )
            health = health_result.stdout.strip()
            return "unhealthy" if health == "unhealthy" else "running"
        elif status in ("exited", "dead"):
            return "stopped"
        elif status == "restarting":
            return "starting"
        return status
    except Exception:
        return "absent"


def management_state() -> str:
    if _http_ok(f"http://localhost:{MANAGEMENT_PORT}/"):
        return "running"
    if _process_running("llmgateway.py"):
        return "starting"
    try:
        result = subprocess.run(
            ["launchctl", "list"], capture_output=True, text=True, timeout=10,
        )
        if MANAGEMENT_LABEL in result.stdout:
            return "stopped"
    except Exception:
        pass
    if MANAGEMENT_PLIST.exists():
        return "stopped"
    return "absent"


def whisper_server_state() -> str:
    if _http_ok(f"http://localhost:{WHISPER_SERVER_DEFAULT_PORT}/health"):
        return "running"
    if _process_running("whisper-server"):
        return "starting"
    try:
        import shutil
        if shutil.which("whisper-server"):
            return "stopped"
    except Exception:
        pass
    return "absent"


# ── Display helpers ───────────────────────────────────────────────────────────

def _status_color(state: str) -> callable:
    return {"running": green, "starting": yellow}.get(state, red)


def _status_icon(state: str) -> str:
    return {"running": "●", "starting": "◐"}.get(state, "○")


def _status_label(state: str) -> str:
    return "not found" if state == "absent" else state


def print_row(name: str, state: str, endpoint: str = "", desc: str = "") -> None:
    color = _status_color(state)
    icon = _status_icon(state)
    label = _status_label(state)
    line = f"  {color(icon)} {name:<14s} {color(f'{label:<12s}')}"
    if endpoint:
        line += f"  {cyan(f'{endpoint:<36s}')}"
    else:
        line += f"  {'':36s}"
    if desc:
        line += f"  {dim(desc)}"
    info(line)
    _log(f"  {name}: {label} {endpoint} {desc}")


def print_path(label: str, path: str, desc: str = "") -> None:
    expanded = str(Path(path).expanduser()) if path.startswith("~") else path
    if not os.path.isabs(expanded):
        expanded = str(REPO_DIR / expanded)
    mark = green("+") if os.path.exists(expanded) else dim(".")
    info(f"  {mark}  {dim(f'{label:<12s}')}  {path:<45s}  {dim(desc)}")


def print_volume(name: str, desc: str = "") -> None:
    try:
        result = subprocess.run(
            ["docker", "volume", "inspect", name],
            capture_output=True, timeout=10,
        )
        mark = green("+") if result.returncode == 0 else dim(".")
    except Exception:
        mark = dim(".")
    info(f"  {mark}  {dim('volume'):<16s}  {name:<45s}  {dim(desc)}")


# ── Docker compose helper ────────────────────────────────────────────────────

def _compose_cmd(*args: str) -> list[str]:
    """Build docker compose command with --env-file and optional observability."""
    cmd = ["docker", "compose", "-f", str(COMPOSE_FILE)]
    if _observability_enabled() and COMPOSE_OBS_FILE.exists():
        cmd.extend(["-f", str(COMPOSE_OBS_FILE)])
    env_file = get_data_dir() / ".env"
    if env_file.exists():
        cmd.extend(["--env-file", str(env_file)])
    cmd.extend(args)
    return cmd


def _venv_python_for_repo(repo_dir: Path) -> str | None:
    candidates = [
        repo_dir / ".venv" / "bin" / "python3",
        repo_dir / ".venv" / "bin" / "python",
    ]
    for candidate in candidates:
        if candidate.exists():
            return str(candidate.resolve())
    return None


def _resolve_compose_service(name: str) -> str:
    return {
        "litellm": "litellm",
        "postgres": "postgres", "db": "postgres",
        "grafana": "grafana",
        "prometheus": "prometheus",
        "loki": "loki",
        "alloy": "alloy",
    }.get(name, "")


# ── Commands ──────────────────────────────────────────────────────────────────

def cmd_status() -> None:
    enabled = _enabled_components()
    data_dir = get_data_dir()
    obs = _observability_enabled()

    blank()
    info(f"  {bold('LLM Gateway — Status')}  {dim(datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S'))}")
    blank()
    header = f"{'COMPONENT':<15s} {'STATUS':<12s} {'ENDPOINT':<38s} DESCRIPTION"
    info(f"  {dim(header)}")
    separator()
    blank()

    # Bare-metal services
    if "management" in enabled:
        print_row("management", management_state(),
                  f"http://localhost:{MANAGEMENT_PORT}", "Gateway web UI + REST API")

    if "whisper-server" in enabled:
        print_row("whisper-server", whisper_server_state(),
                  f"http://localhost:{WHISPER_SERVER_DEFAULT_PORT}", "Speech-to-text (whisper.cpp)")

    blank()

    # Docker containers
    if not docker_available():
        icon = red("○")
        name = "docker".ljust(14)
        status = red("unavailable".ljust(12))
        message = dim("Docker daemon not running")
        info(f"  {icon} {name} {status}  {message}")
        blank()
    else:
        docker_rows = [
            ("llm-gateway",  "litellm",    "http://localhost:4000", "LiteLLM proxy (UI -> /ui)"),
            ("llm-postgres", "postgres",   "",                      "PostgreSQL — spend tracking"),
        ]
        if obs:
            docker_rows.extend([
                ("grafana",      "grafana",    "http://localhost:3000", "Grafana dashboards"),
                ("prometheus",   "prometheus", "http://localhost:9090", "Prometheus metrics"),
                ("loki",         "loki",       "http://localhost:3100", "Loki log aggregation"),
                ("alloy",        "alloy",      "",                      "Grafana Alloy collector"),
            ])
        for container, display, endpoint, desc in docker_rows:
            if display in enabled:
                print_row(display, docker_container_state(container), endpoint, desc)
        blank()

    # Service accounts
    info(f"\n  {dim('Service accounts')}")
    blank()
    user = os.environ.get("USER", "unknown")
    info(f"  {'Host (local):':<18s} {bold(user)}  {dim('management, whisper-server')}")
    info(f"  {'PostgreSQL:':<18s} {bold('litellm')}  {dim('LiteLLM DB (docker stack)')}")

    if obs:
        grafana_user = "admin"
        env_file = data_dir / ".env"
        if env_file.exists():
            try:
                for line in env_file.read_text(errors="replace").splitlines():
                    if line.startswith("GF_SECURITY_ADMIN_USER="):
                        val = line.split("=", 1)[1].strip().strip("'\"")
                        if val:
                            grafana_user = val
            except Exception:
                pass
        info(f"  {'Grafana admin:':<18s} {bold(grafana_user)}  {dim('docker stack (.env)')}")
    blank()

    # Key paths
    header = f"{'PATH':<15s} {'TYPE':<12s} {'':38s} DESCRIPTION"
    info(f"  {dim(header)}")
    separator()

    info(f"\n  {dim('Config files')}")
    blank()
    print_path("config",  str(data_dir / "config" / "llmgateway.yaml"), "gateway config + install choices")
    print_path("config",  "litellm-config.yaml", "litellm: model routing")
    print_path("secrets", str(data_dir / ".env"), "API keys, passwords")

    info(f"\n  {dim('Logs')}")
    blank()
    print_path("log", str(data_dir / "logs" / "gateway.log"), "management service (stdout + stderr)")
    print_path("log", str(data_dir / "logs" / "gw.log"), "gw script log (this run)")

    info(f"\n  {dim('System')}")
    blank()
    print_path("launchd", f"~/Library/LaunchAgents/{MANAGEMENT_LABEL}.plist", "autostart agent")

    info(f"\n  {dim('Docker stack')}")
    blank()
    print_path("docker",  "docker/docker-compose.yml", "core stack (LiteLLM + PostgreSQL)")
    if obs:
        print_path("docker",  "docker/docker-compose.observability.yml", "observability stack")
        print_path("docker",  "docker/prometheus/prometheus.yml", "Prometheus scrape config")
        print_path("docker",  "docker/grafana/provisioning", "Grafana dashboards + data sources")
        print_path("docker",  "docker/alloy/alloy-config.alloy", "Grafana Alloy collector config")

    # Docker volumes
    if docker_available():
        compose_project = ""
        try:
            result = subprocess.run(
                _compose_cmd("config"),
                capture_output=True, text=True, timeout=15,
            )
            for line in result.stdout.splitlines():
                if line.startswith("name:"):
                    compose_project = line.split(":", 1)[1].strip()
                    break
        except Exception:
            pass
        if not compose_project:
            compose_project = "docker"

        info(f"\n  {dim('Docker volumes')}")
        blank()
        print_volume(f"{compose_project}_postgres-data", "PostgreSQL DB")
        if obs:
            print_volume(f"{compose_project}_prometheus-data", "Prometheus TSDB")
            print_volume(f"{compose_project}_loki-data", "Loki log chunks")
            print_volume(f"{compose_project}_grafana-data", "Grafana DB + dashboards")

        info(f"\n  {dim('Docker runtime (host)')}")
        blank()
        print_path("docker", "~/.docker", "Docker CLI config, credentials")
        print_path("docker", "~/Library/Containers/com.docker.docker", "Docker Desktop data")

    blank()
    info(f"  {dim(f'Data dir: {data_dir}')}")
    info(f"  {dim('Commands: ./gw start|stop|restart|logs <component>  |  ./gw uninstall')}")
    blank()


def cmd_start(name: str) -> None:
    if name in ("management", "gateway"):
        info(f"  Starting management service...")
        if MANAGEMENT_PLIST.exists():
            subprocess.run(["launchctl", "load", str(MANAGEMENT_PLIST)],
                           capture_output=True)
        else:
            warn("Launchd plist not installed — starting directly.")
            info(f"  {dim('Install with: python3 scripts/llmgateway.py --install')}")
            python_bin = _venv_python_for_repo(REPO_DIR) or sys.executable
            subprocess.Popen(
                [python_bin, str(MANAGEMENT_SCRIPT)],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
    elif name == "whisper-server":
        info(f"  Starting whisper-server...")
        import shutil
        if not shutil.which("whisper-server"):
            error("whisper-server not found. Install: brew install whisper-cpp")
            return
        subprocess.Popen(
            ["whisper-server", "--host", "0.0.0.0", "--port", str(WHISPER_SERVER_DEFAULT_PORT)],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    elif name == "docker":
        info(f"  Starting Docker Compose stack...")
        subprocess.run(_compose_cmd("up", "-d"))
    else:
        svc = _resolve_compose_service(name)
        if not svc:
            error(f"Unknown component: {name}")
            cmd_usage()
            return
        info(f"  Starting {name}...")
        subprocess.run(_compose_cmd("up", "-d", svc))

    success("Done.")
    _log(f"Started: {name}")


def cmd_stop(name: str) -> None:
    if name in ("management", "gateway"):
        info(f"  Stopping management service...")
        if MANAGEMENT_PLIST.exists():
            subprocess.run(["launchctl", "unload", str(MANAGEMENT_PLIST)],
                           capture_output=True)
        subprocess.run(["pkill", "-f", "llmgateway.py"], capture_output=True)
    elif name == "whisper-server":
        info(f"  Stopping whisper-server...")
        subprocess.run(["pkill", "-f", "whisper-server"], capture_output=True)
    elif name == "docker":
        info(f"  Stopping Docker Compose stack...")
        subprocess.run(_compose_cmd("down"))
    else:
        svc = _resolve_compose_service(name)
        if not svc:
            error(f"Unknown component: {name}")
            cmd_usage()
            return
        info(f"  Stopping {name}...")
        subprocess.run(_compose_cmd("stop", svc))

    success("Done.")
    _log(f"Stopped: {name}")


def cmd_restart(name: str) -> None:
    if name in ("management", "gateway"):
        info(f"  Restarting management service...")
        if MANAGEMENT_PLIST.exists():
            subprocess.run(["launchctl", "unload", str(MANAGEMENT_PLIST)],
                           capture_output=True)
            time.sleep(0.5)
            subprocess.run(["launchctl", "load", str(MANAGEMENT_PLIST)])
        else:
            subprocess.run(["pkill", "-f", "llmgateway.py"], capture_output=True)
            time.sleep(1)
            subprocess.Popen(
                [sys.executable, str(MANAGEMENT_SCRIPT)],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
    elif name == "whisper-server":
        info(f"  Restarting whisper-server...")
        subprocess.run(["pkill", "-f", "whisper-server"], capture_output=True)
        time.sleep(1)
        import shutil
        if shutil.which("whisper-server"):
            subprocess.Popen(
                ["whisper-server", "--host", "0.0.0.0", "--port", str(WHISPER_SERVER_DEFAULT_PORT)],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
    elif name == "docker":
        info(f"  Restarting Docker Compose stack...")
        subprocess.run(_compose_cmd("restart"))
    else:
        svc = _resolve_compose_service(name)
        if not svc:
            error(f"Unknown component: {name}")
            cmd_usage()
            return
        info(f"  Restarting {name}...")
        subprocess.run(_compose_cmd("restart", svc))

    success("Done.")
    _log(f"Restarted: {name}")


def cmd_logs(name: str) -> None:
    data_dir = get_data_dir()

    if name in ("management", "gateway"):
        log_file = data_dir / "logs" / "gateway-stdout.log"
        if log_file.exists():
            info(f"  {dim(f'Tailing {log_file} (Ctrl-C to stop)...')}")
            try:
                subprocess.run(["tail", "-f", str(log_file)])
            except KeyboardInterrupt:
                pass
        else:
            warn(f"Log not found: {log_file}")
            info(f"  {dim('The log is created when the management service runs via launchd.')}")
    elif name == "whisper-server":
        info(f"  {dim(f'No dedicated log for {name}.')}")
        log_file = data_dir / "logs" / "gateway-stdout.log"
        if log_file.exists():
            info(f"  {dim('Management service log may include subprocess output:')}")
            try:
                subprocess.run(["tail", "-f", str(log_file)])
            except KeyboardInterrupt:
                pass
    elif name == "docker":
        subprocess.run(_compose_cmd("logs", "-f", "--tail=50"))
    else:
        svc = _resolve_compose_service(name)
        if not svc:
            error(f"Unknown component: {name}")
            cmd_usage()
            return
        subprocess.run(_compose_cmd("logs", "-f", "--tail=50", svc))


def cmd_uninstall() -> None:
    blank()
    info(f"  {bold('Uninstall')} — deregister autostart, stop services")
    info(f"  {dim('Docker images, data volumes, and config are preserved.')}")
    blank()

    # Management service
    if MANAGEMENT_PLIST.exists():
        info(f"  Unregistering management launchd agent...")
        subprocess.run(["launchctl", "unload", str(MANAGEMENT_PLIST)], capture_output=True)
        MANAGEMENT_PLIST.unlink(missing_ok=True)
        success("done")
    else:
        info(f"  {dim('Management launchd agent: not installed — skipping')}")
    if _process_running("llmgateway.py"):
        info(f"  Stopping management service process...")
        subprocess.run(["pkill", "-f", "llmgateway.py"], capture_output=True)
        success("done")

    # whisper-server
    if _process_running("whisper-server"):
        info(f"  Stopping whisper-server...")
        subprocess.run(["pkill", "-f", "whisper-server"], capture_output=True)
        success("done")

    # Docker
    if docker_available():
        info(f"  Stopping Docker Compose stack (images + volumes preserved)...")
        subprocess.run(_compose_cmd("down"), capture_output=True)
        success("done")
    else:
        info(f"  {dim('Docker not available — skipping')}")

    blank()
    info(f"  {yellow('Note:')} To restart:      {cyan('./gw start docker')}")
    info(f"  {yellow('Note:')} To reinstall:     {cyan('python3 scripts/llmgateway.py --install')}")
    blank()
    _log("Uninstall completed")


