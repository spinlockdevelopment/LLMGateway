    info(f"    ./gw start <component>       Start a component")
    info(f"    ./gw stop <component>        Stop a component")
    info(f"    ./gw restart <component>     Restart a component")
    info(f"    ./gw logs <component>        Tail logs for a component")
    info(f"    ./gw uninstall               Deregister autostart, stop all")
    blank()
    info(f"  {bold('Components:')}")
    info(f"    {'management':<14s}  Gateway web UI + management service (launchd)")
    info(f"    {'whisper-server':<14s}  whisper.cpp STT   -> http://localhost:8083")
    info(f"    {'docker':<14s}  Entire Docker Compose stack")
    info(f"    {'litellm':<14s}  LiteLLM proxy     -> http://localhost:4000")
    info(f"    {'postgres':<14s}  PostgreSQL container")
    if _observability_enabled():
        info(f"    {'grafana':<14s}  Grafana dashboards -> http://localhost:3000")
        info(f"    {'prometheus':<14s}  Prometheus metrics -> http://localhost:9090")
        info(f"    {'loki':<14s}  Loki log aggregation -> http://localhost:3100")
        info(f"    {'alloy':<14s}  Grafana Alloy collector")
    blank()


# ── Main ──────────────────────────────────────────────────────────────────────

def main() -> int:
    _setup_log_file()
    _log(f"gw invoked: {' '.join(sys.argv)}")

    args = sys.argv[1:]
    cmd = args[0] if args else "status"
    component = args[1] if len(args) > 1 else None

    if cmd in ("", "-s", "status"):
        cmd_status()
    elif cmd == "start":
        if not component:
            error("component name required")
            cmd_usage()
            return 1
        cmd_start(component)
    elif cmd == "stop":
        if not component:
            error("component name required")
            cmd_usage()
            return 1
        cmd_stop(component)
    elif cmd == "restart":
        if not component:
            error("component name required")
            cmd_usage()
            return 1
        cmd_restart(component)
    elif cmd == "logs":
        if not component:
            error("component name required")
            cmd_usage()
            return 1
        cmd_logs(component)
    elif cmd == "uninstall":
        cmd_uninstall()
    elif cmd in ("-h", "--help", "help"):
        cmd_usage()
    else:
        error(f"Unknown command: {cmd}")
        cmd_usage()
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
