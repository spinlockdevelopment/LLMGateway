# ── Main ──────────────────────────────────────────────────────────────────────

def main() -> int:
    _setup_log_file()
    _log(f"gw invoked: {' '.join(sys.argv)}")

    args = sys.argv[1:]
    cmd = args[0] if args else "status"
    component = args[1] if len(args) > 1 else None

    if cmd in ("", "-s", "status"):
        cmd_status()
    elif cmd == "start":
        if not component:
            error("component name required")
            cmd_usage()
            return 1
        cmd_start(component)
    elif cmd == "stop":
        if not component:
            error("component name required")
            cmd_usage()
            return 1
        cmd_stop(component)
    elif cmd == "restart":
        if not component:
            error("component name required")
            cmd_usage()
            return 1
        cmd_restart(component)
    elif cmd == "logs":
        if not component:
            error("component name required")
            cmd_usage()
            return 1
        cmd_logs(component)
    elif cmd == "uninstall":
        cmd_uninstall()
    elif cmd in ("-h", "--help", "help"):
        cmd_usage()
    else:
        error(f"Unknown command: {cmd}")
        cmd_usage()
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
