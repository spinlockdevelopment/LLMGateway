# ============================================================
# LLM Gateway — Environment Variables
# ============================================================
# This file is the template for the dashboard Secrets UI.
# Copy to .env and set values; the management app and Docker
# stack read .env. Blank entries are not written when saving
# from the UI. Base URL vars are only written when their
# associated API key is set. DATABASE_URL is set by the stack
# and is not editable in the Secrets UI. Everything is optional.
# ============================================================

# ── LiteLLM Proxy ───────────────────────────────────────────
# Master key for admin API: /key/generate, /team/new, /ui
# Must start with sk-. Use for dashboard login and virtual keys.
LITELLM_MASTER_KEY=sk-gateway-master-change-me

# PostgreSQL URL. Set by Docker stack; do not edit in Secrets UI.
DATABASE_URL=postgresql://litellm:litellm@postgres:5432/litellm

# ── OpenRouter (optional) ────────────────────────────────────
# One key accesses Anthropic, OpenAI, Google, 200+ models.
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Custom base only written when OPENROUTER_API_KEY is set.
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# ── Anthropic (optional) ─────────────────────────────────────
# Used when litellm-config.yaml references anthropic/ models.
ANTHROPIC_API_KEY=

# Custom base only written when ANTHROPIC_API_KEY is set.
ANTHROPIC_API_BASE=https://api.anthropic.com

# ── OpenAI (optional) ────────────────────────────────────────
# For openai/ models when not using OpenRouter.
OPENAI_API_KEY=

# Custom base only written when OPENAI_API_KEY is set. LiteLLM also accepts OPENAI_API_BASE.
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI organization ID for usage attribution.
OPENAI_ORGANIZATION=

# ── Google / Gemini (optional) ────────────────────────────────
# For gemini/ or vertex_ai/ models. Google AI Studio key.
GEMINI_API_KEY=

# Custom base only written when GEMINI_API_KEY is set.
GEMINI_API_BASE=https://generativelanguage.googleapis.com

# ── xAI / Grok (optional) ────────────────────────────────────
# For xai/ models (e.g. grok). Get key: https://console.x.ai
XAI_API_KEY=

# Custom base only written when XAI_API_KEY is set.
XAI_API_BASE=https://api.x.ai/v1

# ── Azure OpenAI (optional) ──────────────────────────────────
# For azure/ models. Set key and base; version below or in config.
AZURE_API_KEY=

# Azure endpoint base; only written when AZURE_API_KEY is set.
AZURE_API_BASE=

# Azure API version (e.g. 2024-02-15-preview); only written when AZURE_API_KEY is set.
AZURE_API_VERSION=

# ── Perplexity (optional) ─────────────────────────────────────
# For perplexity/ models (e.g. sonar). Get key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# ── Other providers (optional) ────────────────────────────────
# Set if you use these in litellm-config.yaml.
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
COHERE_API_KEY=
FIREWORKS_API_KEY=
REPLICATE_API_KEY=

# ── LiteLLM Proxy: OAuth 2.0 (optional, enterprise) ─────────
# Validate OAuth tokens for /chat, /embeddings. Enable in config: enable_oauth2_auth: true
# Docs: https://docs.litellm.ai/docs/proxy/oauth2
OAUTH_TOKEN_INFO_ENDPOINT=
OAUTH_USER_ID_FIELD_NAME=sub
OAUTH_USER_ROLE_FIELD_NAME=role
OAUTH_USER_TEAM_ID_FIELD_NAME=team_id

# ── Grafana (observability dashboard) ────────────────────────
# Default login for http://localhost:3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=llmgateway
