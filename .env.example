# ============================================================
# LLM Gateway — Environment Variables
# ============================================================
# Copy to .env and fill in your values.
# Only OPENROUTER_API_KEY and LITELLM_MASTER_KEY are required.
# ============================================================

# ── Provider API Keys ────────────────────────────────────────
# OpenRouter (primary — one key accesses Anthropic, OpenAI, Google, 200+ models)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Anthropic direct (optional — fallback when OpenRouter is unavailable)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Uncomment to enable direct access (not through OpenRouter)
# OPENAI_API_KEY=sk-your-key-here
# GOOGLE_API_KEY=your-key-here


# ── LiteLLM Proxy ───────────────────────────────────────────
# Master key for admin API (/key/generate, /team/new, /ui)
# Must start with sk-
LITELLM_MASTER_KEY=sk-gateway-master-change-me

# PostgreSQL connection (used for virtual keys, spend tracking)
DATABASE_URL=postgresql://litellm:litellm@postgres:5432/litellm

# ── Grafana ──────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=llmgateway

