# LLM Gateway Configuration
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_LOG_LEVEL=info

# Config file paths (relative to project root)
ROUTING_CONFIG=config/routing.yaml
PROVIDERS_CONFIG=config/providers.yaml
AGENTS_CONFIG=config/agents.yaml
LOCAL_MODELS_CONFIG=config/local_models.yaml

# Provider API keys
OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=llm-gateway

# Database (usage tracking)
USAGE_DB_PATH=data/usage.db

# Rate limiting
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10

# Local inference
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_INFERENCE_TIMEOUT=120
