{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Requests per Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(llm_gateway_llm_gateway_requests_total[5m])",
          "legendFormat": "{{pseudo_model}} → {{model}}"
        }
      ]
    },
    {
      "title": "Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(llm_gateway_llm_gateway_latency_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(llm_gateway_llm_gateway_latency_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(llm_gateway_llm_gateway_latency_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Tokens In / Out per Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(llm_gateway_llm_gateway_tokens_in_total[5m])",
          "legendFormat": "in: {{model}}"
        },
        {
          "expr": "rate(llm_gateway_llm_gateway_tokens_out_total[5m])",
          "legendFormat": "out: {{model}}"
        }
      ]
    },
    {
      "title": "Estimated Cost per Agent ($)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "increase(llm_gateway_llm_gateway_cost_total[1h])",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "title": "Routing Decisions",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "increase(llm_gateway_llm_gateway_routing_decisions_total[1h])",
          "legendFormat": "{{strategy}}: {{pseudo_model}}"
        }
      ]
    },
    {
      "title": "Gateway Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 16, "x": 8, "y": 16 },
      "datasource": { "type": "loki" },
      "targets": [
        {
          "expr": "{container=\"llm-gateway\"} | json"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["llm", "gateway"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "LLM Gateway",
