{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Requests per Model (rate/5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "rate(litellm_requests_metric_total[5m])",
          "legendFormat": "{{model}} ({{api_provider}})"
        }
      ]
    },
    {
      "title": "Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(litellm_request_total_latency_metric_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(litellm_request_total_latency_metric_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(litellm_request_total_latency_metric_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Tokens (input + output) per Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "rate(litellm_input_tokens_metric_total[5m])",
          "legendFormat": "in: {{model}}"
        },
        {
          "expr": "rate(litellm_output_tokens_metric_total[5m])",
          "legendFormat": "out: {{model}}"
        }
      ]
    },
    {
      "title": "Spend per API Key ($)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "increase(litellm_spend_metric_total[1h])",
          "legendFormat": "key: {{hashed_api_key}}"
        }
      ]
    },
    {
      "title": "Deployment Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "increase(litellm_deployment_failure_responses_total[15m])",
          "legendFormat": "{{requested_model}} ({{exception_class}})"
        }
      ]
    },
    {
      "title": "Deployment Latency Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "rate(litellm_request_total_latency_metric_bucket[5m])",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    },
    {
      "title": "Gateway Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "loki" },
      "targets": [
        {
          "expr": "{container=\"llm-gateway\"} | json"
        }
      ]
    },
    {
      "title": "Active Requests (in-flight)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "litellm_remaining_requests_metric"
        }
      ]
    },
    {
      "title": "Remaining Budget ($)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "litellm_remaining_budget_metric"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["llm", "gateway", "litellm"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "LLM Gateway",
  "uid": "llm-gateway-main"
}
